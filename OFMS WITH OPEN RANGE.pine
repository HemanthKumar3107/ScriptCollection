//@version=6
indicator("Omni Flow Matrix Structure With Open Range", overlay=true, shorttitle="OFMS By Hemanth", max_lines_count=500, max_labels_count=500)
// TYPES & HELPERS
type smc_pivot
    float price
    int   time
    int   index
type smc_ob
    float top
    float bottom
    int   start_time 
    int   bias
    box   display_box

// --- Universal Visual Helpers ---
float d_offset = ta.atr(14) * 0.7  // Adjust 0.7 to change label distance
float d_offset2 = ta.atr(14) * 1.0 // Adjust 1.0 to change label distance
float d_offset3 = ta.atr(14) * 0.1 // Adjust for div engine labels

// --- Global Strategy Timing ---
is_low_tf = timeframe.isintraday and timeframe.multiplier <= 15
is_last_bar_of_day = (time_close("D") - time_close) <= (timeframe.multiplier * 60 * 1000)
force_close = is_low_tf and is_last_bar_of_day
is_first_candle    = ta.change(time("D")) != 0
dt_allowed         = not (is_low_tf and (is_first_candle or is_last_bar_of_day))
gap_entry_allowed  = not (is_low_tf and (is_first_candle or is_last_bar_of_day))

// --- Global Tracking Variables (Place near top of script) ---
var bool  t_milestone_hit = false
var float t_locked_pts    = 0.0

// -------------------- #01 SuperTrend --------------------------------------------------------------------------------------------------------------------------------------------
grp_st = "主 SuperTrend"
show_st         = input.bool(true, 'Show SuperTrend', group=grp_st)
st_atr_len      = input.int(10, 'ATR Length', group=grp_st)
st_factor       = input.float(3.0, 'Factor', group=grp_st)
st_col_bull     = input.color(color.lime, "Bullish Color", group=grp_st)
st_col_bear     = input.color(color.red, "Bearish Color", group=grp_st)
[st_val, st_dir] = ta.supertrend(st_factor, st_atr_len)
plot(show_st ? st_val : na, title="SuperTrend", color=st_dir < 0 ? st_col_bull : st_col_bear, linewidth=2, style=plot.style_linebr, linestyle=plot.linestyle_dashed)

// -------------------- #02 EMA CLOUD ---------------------------------------------------------------------------------------------------------------------------------------------
grp_cloud = "云 EMA Cloud"
ema_cloud_show   = input.bool(true, 'Show EMA Cloud', group=grp_cloud)
ema_fast_len     = input.int(9, 'Fast EMA Length', group=grp_cloud)
ema_slow_len     = input.int(21, 'Slow EMA Length', group=grp_cloud)
cloud_col_bull   = input.color(color.new(color.green, 70), "Bullish Cloud", group=grp_cloud)
cloud_col_bear   = input.color(color.new(color.red, 70), "Bearish Cloud", group=grp_cloud)
ema_f = ta.ema(close, ema_fast_len)
ema_s = ta.ema(close, ema_slow_len)
p_ef = plot(ema_cloud_show ? ema_f : na, title="Cloud Fast EMA", color=color.gray, display=display.none)
p_es = plot(ema_cloud_show ? ema_s : na, title="Cloud Slow EMA", color=color.gray, display=display.none)
fill(p_ef, p_es, color=ema_cloud_show ? (ema_f >= ema_s ? cloud_col_bull : cloud_col_bear) : na, title="EMA Cloud Fill")

// -------------------- #03 EXTRA EMA ---------------------------------------------------------------------------------------------------------------------------------------------
grp_extra = "线 Extra EMA"
show_extra_ema   = input.bool(true, "Show Extra EMA", group=grp_extra)
extra_ema_len    = input.int(5, "Length", minval=1, group=grp_extra)
extra_ema_col    = input.color(color.white, "EMA Color", group=grp_extra)
extra_ema = ta.ema(close, extra_ema_len)
plot(show_extra_ema ? extra_ema : na, title="Extra EMA", color=extra_ema_col, linewidth=2)

// -------------------- #04 EMA CROSS ---------------------------------------------------------------------------------------------------------------------------------------------
grp_cross = "交 EMA Cross"
show_ema_plots   = input.bool(true, "Show Cross EMA Lines", group=grp_cross)
cross_fast_len   = input.int(50, "Fast EMA Length", group=grp_cross)
cross_slow_len   = input.int(200, "Slow EMA Length", group=grp_cross)
cross_f_col      = input.color(color.orange, "Fast EMA Color", group=grp_cross)
cross_s_col      = input.color(color.yellow, "Slow EMA Color", group=grp_cross)
ema_fast_plot = ta.ema(close, cross_fast_len)
ema_slow_plot = ta.ema(close, cross_slow_len)
plot(show_ema_plots ? ema_fast_plot : na, title="EMA Cross Fast", color=cross_f_col, linewidth=2)
plot(show_ema_plots ? ema_slow_plot : na, title="EMA Cross Slow", color=cross_s_col, linewidth=2)

// -------------------- #05 VWAP --------------------------------------------------------------------------------------------------------------------------------------------------
grp_vwap    = "量 VWAP & Bands"
show_vwap   = input.bool(true, "Show VWAP Line", group=grp_vwap)
vwap_src    = input.source(hlc3, "Source", group=grp_vwap)
hide_on_1d  = input.bool(true, "Hide on 1D or Above", group=grp_vwap)
show_b1     = input.bool(true, "Show Band 1 Lines", group=grp_vwap, inline="b1")
mult_1      = input.float(1.0, "Mult 1", step=0.5, group=grp_vwap, inline="b1")
show_f1     = input.bool(true, "Show Band 1 Fill", group=grp_vwap)
show_b2     = input.bool(false, "Show Band 2 Lines", group=grp_vwap, inline="b2")
mult_2      = input.float(2.0, "Mult 2", step=0.5, group=grp_vwap, inline="b2")
show_f2     = input.bool(false, "Show Band 2 Fill", group=grp_vwap)
vwap_col    = input.color(#2962FF, "VWAP Line", group=grp_vwap)
b1_col      = input.color(color.new(color.green, 30), "Band 1 Color", group=grp_vwap)
b2_col      = input.color(color.new(color.red, 30), "Band 2 Color", group=grp_vwap)
fill_col1   = input.color(color.new(color.blue, 95), "Cloud Fill 1", group=grp_vwap)
fill_col2   = input.color(color.new(color.red, 95), "Cloud Fill 2", group=grp_vwap)
is_new_session = ta.change(time("D")) != 0
is_allowed_tf  = not (hide_on_1d and (timeframe.isdaily or timeframe.isweekly or timeframe.ismonthly))
float v_val  = na
float v_up1  = na
float v_lo1  = na
float v_up2  = na
float v_lo2  = na
if is_allowed_tf
    [_v, _top, _] = ta.vwap(vwap_src, is_new_session, 1)
    v_val := _v
    float stdev_abs = _top - _v
    v_up1 := _v + (stdev_abs * mult_1)
    v_lo1 := _v - (stdev_abs * mult_1)
    v_up2 := _v + (stdev_abs * mult_2)
    v_lo2 := _v - (stdev_abs * mult_2)
p_v_main = plot(show_vwap and is_allowed_tf ? v_val : na, "VWAP Main", color=vwap_col, linewidth=2)
p_v_up1  = plot(show_b1 and is_allowed_tf ? v_up1 : na, "VWAP Upper 1", color=b1_col)
p_v_lo1  = plot(show_b1 and is_allowed_tf ? v_lo1 : na, "VWAP Lower 1", color=b1_col)
fill(p_v_up1, p_v_lo1, show_f1 and is_allowed_tf ? fill_col1 : na, title="VWAP Fill 1")
p_v_up2  = plot(show_b2 and is_allowed_tf ? v_up2 : na, "VWAP Upper 2", color=b2_col)
p_v_lo2  = plot(show_b2 and is_allowed_tf ? v_lo2 : na, "VWAP Lower 2", color=b2_col)
fill(p_v_up2, p_v_lo2, show_f2 and is_allowed_tf ? fill_col2 : na, title="VWAP Fill 2")

// -------------------- #06 TRAMA -------------------------------------------------------------------------------------------------------------------------------------------------
grp_trama = "量 TRAMA"
show_trama      = input.bool(true, 'Show TRAMA', group=grp_trama)
trama_len       = input.int(99, 'Length', group=grp_trama)
trama_col       = input.color(color.gray, "TRAMA Color", group=grp_trama)
var float trama_ama = na
hh = ta.change(ta.highest(close, trama_len)) > 0 ? 1 : 0
ll = ta.change(ta.lowest(close, trama_len)) < 0 ? 1 : 0
tc = math.pow(ta.sma(hh != 0 or ll != 0 ? 1 : 0, trama_len), 2)
trama_ama := nz(trama_ama, close) + tc * (close - nz(trama_ama, close))
plot(show_trama ? trama_ama : na, title="TRAMA", color=trama_col, linewidth=2, linestyle=plot.linestyle_dotted)

// -------------------- #07 BOLLINGER BANDS ---------------------------------------------------------------------------------------------------------------------------------------
grp_bb   = "带 Bollinger Bands"
show_bb  = input.bool(true, "Show BB", group=grp_bb)
bb_len   = input.int(20, "Length", group=grp_bb)
bb_mult  = input.float(2.0, "Multiplier", group=grp_bb)
bb_col_fill = input.color(color.new(#1e1e1e, 75), "BB Fill Color", group=grp_bb)
[bb_mid, bb_up, bb_low] = ta.bb(close, bb_len, bb_mult)
p_up  = plot(show_bb ? bb_up : na,  "BB Upper", color=color.gray, display=display.none)
p_low = plot(show_bb ? bb_low : na, "BB Lower", color=color.gray, display=display.none)
fill(p_up, p_low, color=show_bb ? bb_col_fill : na, title="BB Fill")

// -------------------- #08 HTF PIVOTS --------------------------------------------------------------------------------------------------------------------------------------------
grp_piv = "准 HTF Pivots"
show_pivots    = input.bool(true, 'Show Pivots', group=grp_piv)
pivot_method   = input.string('Classical', 'Pivot type', options=['Classical','Fibonacci','Camarilla','Woodie'], group=grp_piv)
pivot_tf       = input.string('D', 'Pivot TF', options=['D','W','M'], group=grp_piv)
pivot_color    = input.color(color.orange, "Pivot (P) Color", group=grp_piv)
r_color        = input.color(color.red, "Resistance Color", group=grp_piv)
s_color        = input.color(color.green, "Support Color", group=grp_piv)
p_line_style   = input.string("Solid", "Line Style", options=["Solid","Dashed","Dotted"], group=grp_piv)
pivot_width    = input.int(1, 'Line Width', minval=1, group=grp_piv)
p_style = p_line_style == "Dashed" ? line.style_dashed : p_line_style == "Dotted" ? line.style_dotted : line.style_solid
f_piv_line(x, y, col, w, stl) => 
    line.new(x, y, bar_index, y, xloc.bar_index, extend.none, col, stl, w)
f_piv_lbl(x, y, txt, col) => 
    label.new(x, y, txt, xloc.bar_index, yloc.price, color.new(color.black, 100), label.style_label_left, col, size.small)
pivot_tf_res = pivot_tf == 'D' ? 'D' : pivot_tf == 'W' ? 'W' : 'M'
sym_h = request.security(syminfo.tickerid, pivot_tf_res, high[1])
sym_l = request.security(syminfo.tickerid, pivot_tf_res, low[1])
sym_c = request.security(syminfo.tickerid, pivot_tf_res, close[1])
range_htf = sym_h - sym_l
pp = switch pivot_method
    'Classical' => (sym_h + sym_l + sym_c)/3.0
    'Fibonacci' => (sym_h + sym_l + sym_c)/3.0
    'Camarilla' => sym_c
    'Woodie'    => (sym_h + sym_l + 2.0*sym_c)/4.0
    => (sym_h + sym_l + sym_c)/3.0
var float r1 = na, var float r2 = na, var float r3 = na
var float s1 = na, var float s2 = na, var float s3 = na
if pivot_method == 'Classical' or pivot_method == 'Woodie'
    r1 := 2*pp - sym_l, s1 := 2*pp - sym_h
    r2 := pp + range_htf, s2 := pp - range_htf
    r3 := pp + 2*range_htf, s3 := pp - 2*range_htf
else if pivot_method == 'Fibonacci'
    r1 := pp + 0.382*range_htf, s1 := pp - 0.382*range_htf
    r2 := pp + 0.618*range_htf, s2 := pp - 0.618*range_htf
    r3 := pp + 1.000*range_htf, s3 := pp - 1.000*range_htf
else if pivot_method == 'Camarilla'
    r1 := sym_c + (range_htf*1.0833), s1 := sym_c - (range_htf*1.0833)
    r2 := sym_c + (range_htf*1.1666), s2 := sym_c - (range_htf*1.1666)
    r3 := sym_c + (range_htf*1.25), s3 := sym_c - (range_htf*1.25)
var line pp_l = na, var line r1_l = na, var line r2_l = na, var line r3_l = na
var line s1_l = na, var line s2_l = na, var line s3_l = na
var label pp_lb = na, var label r1_lb = na, var label r2_lb = na, var label r3_lb = na
var label s1_lb = na, var label s2_lb = na, var label s3_lb = na
period_changed = ta.change(time(pivot_tf_res)) != 0
period_start = bar_index - nz(ta.barssince(period_changed), 0)
if period_changed
    line.delete(pp_l), line.delete(r1_l), line.delete(r2_l), line.delete(r3_l), line.delete(s1_l), line.delete(s2_l), line.delete(s3_l)
    label.delete(pp_lb), label.delete(r1_lb), label.delete(r2_lb), label.delete(r3_lb), label.delete(s1_lb), label.delete(s2_lb), label.delete(s3_lb)
    if show_pivots
        pp_l := f_piv_line(period_start, pp, pivot_color, pivot_width, p_style)
        r1_l := f_piv_line(period_start, r1, r_color, pivot_width, p_style)
        r2_l := f_piv_line(period_start, r2, r_color, pivot_width, p_style)
        r3_l := f_piv_line(period_start, r3, r_color, pivot_width, p_style)
        s1_l := f_piv_line(period_start, s1, s_color, pivot_width, p_style)
        s2_l := f_piv_line(period_start, s2, s_color, pivot_width, p_style)
        s3_l := f_piv_line(period_start, s3, s_color, pivot_width, p_style)
        pp_lb := f_piv_lbl(bar_index + 3, pp, "P", pivot_color)
        r1_lb := f_piv_lbl(bar_index + 3, r1, "R1", r_color)
        r2_lb := f_piv_lbl(bar_index + 3, r2, "R2", r_color)
        r3_lb := f_piv_lbl(bar_index + 3, r3, "R3", r_color)
        s1_lb := f_piv_lbl(bar_index + 3, s1, "S1", s_color)
        s2_lb := f_piv_lbl(bar_index + 3, s2, "S2", s_color)
        s3_lb := f_piv_lbl(bar_index + 3, s3, "S3", s_color)
if show_pivots and not na(pp_l)
    lbl_x = bar_index + 3
    line.set_xy1(pp_l, period_start, pp), line.set_xy2(pp_l, bar_index, pp), label.set_xy(pp_lb, lbl_x, pp)
    line.set_xy1(r1_l, period_start, r1), line.set_xy2(r1_l, bar_index, r1), label.set_xy(r1_lb, lbl_x, r1)
    line.set_xy1(r2_l, period_start, r2), line.set_xy2(r2_l, bar_index, r2), label.set_xy(r2_lb, lbl_x, r2)
    line.set_xy1(r3_l, period_start, r3), line.set_xy2(r3_l, bar_index, r3), label.set_xy(r3_lb, lbl_x, r3)
    line.set_xy1(s1_l, period_start, s1), line.set_xy2(s1_l, bar_index, s1), label.set_xy(s1_lb, lbl_x, s1)
    line.set_xy1(s2_l, period_start, s2), line.set_xy2(s2_l, bar_index, s2), label.set_xy(s2_lb, lbl_x, s2)
    line.set_xy1(s3_l, period_start, s3), line.set_xy2(s3_l, bar_index, s3), label.set_xy(s3_lb, lbl_x, s3)

// -------------------- #09 YESTERDAY HIGH / LOW ----------------------------------------------------------------------------------------------------------------------------------
grp_hl = "历 Yesterday HL"
show_yest_hl    = input.bool(true, 'Show Yesterday HL', group=grp_hl)
y_h_col         = input.color(color.new(color.gray, 0), "YH Color", group=grp_hl)
y_l_col         = input.color(color.new(color.gray, 0), "YL Color", group=grp_hl)
y_line_style_in = input.string("Dotted", "Line Style", options=["Solid","Dashed","Dotted"], group=grp_hl)
y_line_width    = input.int(2, "Line Width", minval=1, group=grp_hl)
y_show_label    = input.bool(true, "Show Labels", group=grp_hl)
y_style = y_line_style_in == "Dashed" ? line.style_dashed : y_line_style_in == "Dotted" ? line.style_dotted : line.style_solid
y_h = request.security(syminfo.tickerid, 'D', high[1])
y_l = request.security(syminfo.tickerid, 'D', low[1])
var line yh_line = na, var line yl_line = na
var label yh_lbl = na, var label yl_lbl = na
if ta.change(time('D')) != 0
    line.delete(yh_line), line.delete(yl_line)
    label.delete(yh_lbl), label.delete(yl_lbl)
    if show_yest_hl
        yh_line := line.new(bar_index, y_h, bar_index + 3, y_h, xloc.bar_index, extend.none, y_h_col, y_style, y_line_width)
        yl_line := line.new(bar_index, y_l, bar_index + 3, y_l, xloc.bar_index, extend.none, y_l_col, y_style, y_line_width)
        if y_show_label
            yh_lbl := label.new(bar_index + 3, y_h, "YH", xloc=xloc.bar_index, textcolor=y_h_col, style=label.style_label_left, size=size.small, color=color.new(color.black, 100))
            yl_lbl := label.new(bar_index + 3, y_l, "YL", xloc=xloc.bar_index, textcolor=y_l_col, style=label.style_label_left, size=size.small, color=color.new(color.black, 100))
else if show_yest_hl and not na(yh_line)
    line.set_xy1(yh_line, line.get_x1(yh_line), y_h), line.set_xy2(yh_line, bar_index + 3, y_h)
    line.set_xy1(yl_line, line.get_x1(yl_line), y_l), line.set_xy2(yl_line, bar_index + 3, y_l)
    if y_show_label
        label.set_xy(yh_lbl, bar_index + 3, y_h), label.set_xy(yl_lbl, bar_index + 3, y_l)

// -------------------- #10 SMC ENGINE --------------------------------------------------------------------------------------------------------------------------------------------
grp_smc = "体 SMC Settings"
show_ext_struct = input.bool(true, "Show External (BOS/CHoCH)", group=grp_smc)
swing_len       = input.int(50, "External Swing Length", group=grp_smc)
show_int_struct = input.bool(true, "Show Internal (iMSS)", group=grp_smc)
int_swing_len   = input.int(7, "Internal Swing Length", group=grp_smc) 
show_smc_ob     = input.bool(true, "Show Order Blocks", group=grp_smc)
show_pd_zones   = input.bool(true, "Show Premium/Discount", group=grp_smc)
bull_ob_col = color.new(#085d99, 90)
bear_ob_col = color.new(#f25236, 90)
var smc_pivot last_h = smc_pivot.new(na, na, na)
var smc_pivot last_l = smc_pivot.new(na, na, na)
var int smc_trend    = 0
var bool h_act       = false
var bool l_act       = false
var smc_ob[] ob_array = array.new<smc_ob>()
ph = ta.pivothigh(high, swing_len, swing_len)
pl = ta.pivotlow(low, swing_len, swing_len)
var float int_h = na, var float int_l = na
var int int_trend = 0
iph = ta.pivothigh(high, int_swing_len, int_swing_len)
ipl = ta.pivotlow(low, int_swing_len, int_swing_len)
if not na(iph) 
    int_h := iph
if not na(ipl) 
    int_l := ipl
if not na(ph) 
    last_h := smc_pivot.new(ph, time[swing_len], bar_index[swing_len]), h_act := true
if not na(pl) 
    last_l := smc_pivot.new(pl, time[swing_len], bar_index[swing_len]), l_act := true
var line active_h_line = na
var line active_l_line = na
var line active_int_h = na
var line active_int_l = na
if not na(ph)
    line.delete(active_h_line)
    active_h_line := line.new(bar_index[swing_len], ph, bar_index, ph, color=color.new(color.gray, 50), style=line.style_solid)
if not na(active_h_line) and h_act
    line.set_x2(active_h_line, bar_index)
if h_act and close > last_h.price
    if show_ext_struct
        string txt = smc_trend == -1 ? "CHoCH" : "BOS"
        int mid_x = math.round((line.get_x1(active_h_line) + bar_index) / 2)
        line.set_x2(active_h_line, bar_index)
        line.set_color(active_h_line, color.new(color.green, 20))
        label.new(mid_x, last_h.price, txt, color=color.new(color.black, 100), textcolor=color.green, style=label.style_label_down, size=size.tiny)
    smc_trend := 1, h_act := false, active_h_line := na
if not na(pl)
    line.delete(active_l_line)
    active_l_line := line.new(bar_index[swing_len], pl, bar_index, pl, color=color.new(color.gray, 50), style=line.style_solid)
if not na(active_l_line) and l_act
    line.set_x2(active_l_line, bar_index)
if l_act and close < last_l.price
    if show_ext_struct
        string txt = smc_trend == 1 ? "CHoCH" : "BOS"
        int mid_x = math.round((line.get_x1(active_l_line) + bar_index) / 2)
        line.set_x2(active_l_line, bar_index)
        line.set_color(active_l_line, color.new(color.red, 20))
        label.new(mid_x, last_l.price, txt, color=color.new(color.black, 100), textcolor=color.red, style=label.style_label_up, size=size.tiny)
    smc_trend := -1, l_act := false, active_l_line := na
if show_int_struct
    if not na(iph)
        line.delete(active_int_h)
        active_int_h := line.new(bar_index[int_swing_len], iph, bar_index, iph, color=color.new(color.gray, 70), style=line.style_dashed) 
    if not na(active_int_h) and not na(int_h)
        line.set_x2(active_int_h, bar_index)
    if not na(int_h) and close > int_h
        if int_trend == -1
            int mid_x = math.round((line.get_x1(active_int_h) + bar_index) / 2)
            line.set_x2(active_int_h, bar_index)
            line.set_color(active_int_h, color.new(color.green, 50))
            label.new(mid_x, int_h, "iMSS", color=na, textcolor=color.new(color.green, 40), size=size.tiny, style=label.style_label_down)
        int_trend := 1, int_h := na, active_int_h := na
    if not na(ipl)
        line.delete(active_int_l)
        active_int_l := line.new(bar_index[int_swing_len], ipl, bar_index, ipl, color=color.new(color.gray, 70), style=line.style_dashed)
    if not na(active_int_l) and not na(int_l)
        line.set_x2(active_int_l, bar_index)
    if not na(int_l) and close < int_l
        if int_trend == 1
            int mid_x = math.round((line.get_x1(active_int_l) + bar_index) / 2)
            line.set_x2(active_int_l, bar_index)
            line.set_color(active_int_l, color.new(color.red, 50))
            label.new(mid_x, int_l, "iMSS", color=na, textcolor=color.new(color.red, 40), size=size.tiny, style=label.style_label_up)
        int_trend := -1, int_l := na, active_int_l := na
var line eq_line = na
var box pd_box = na
if show_pd_zones and not na(last_h.price) and not na(last_l.price) and not na(last_h.index) and not na(last_l.index)
    float equilibrium = (last_h.price + last_l.price) / 2
    int start_idx = math.max(bar_index - 499, math.min(last_h.index, last_l.index))
    line.delete(eq_line)
    eq_line := line.new(start_idx, equilibrium, bar_index, equilibrium, color=color.new(color.gray, 50), style=line.style_dotted)
    box.delete(pd_box)
    color pd_bg = close > equilibrium ? color.new(color.red, 95) : color.new(color.green, 95) 
    pd_box := box.new(start_idx, last_h.price, bar_index, last_l.price, bgcolor=pd_bg, border_color=na)
if show_smc_ob
    if not na(ph)
        array.push(ob_array, smc_ob.new(high[swing_len], math.max(open[swing_len], close[swing_len]), time[swing_len], -1, box.new(bar_index[swing_len], high[swing_len], bar_index, math.max(open[swing_len], close[swing_len]), bgcolor=bear_ob_col, border_color=na)))
    if not na(pl)
        array.push(ob_array, smc_ob.new(math.min(open[swing_len], close[swing_len]), low[swing_len], time[swing_len], 1, box.new(bar_index[swing_len], math.min(open[swing_len], close[swing_len]), bar_index, low[swing_len], bgcolor=bull_ob_col, border_color=na)))
    if array.size(ob_array) > 0
        for i = array.size(ob_array) - 1 to 0
            e = array.get(ob_array, i)
            box.set_right(e.display_box, bar_index)
            if (e.bias == -1 and close > e.top) or (e.bias == 1 and close < e.bottom)
                box.delete(e.display_box), array.remove(ob_array, i)

// -------------------- #11 DIVERGENCE ENGINE -------------------------------------------------------------------------------------------------------------------------------------
grp_div = "量 Divergence Settings"
show_div_engine   = input.bool(true, "Enable Divergence Engine", group=grp_div)
div_source        = input.string("Both", "Divergence Source", options=["RSI Only", "MACD Only", "Both"], group=grp_div)
div_logic_mode    = input.string("Trend Only", "Divergence Mode", options=["Trend Only", "Reversal Only", "Both"], group=grp_div)
div_allow_hidden  = input.bool(true, "Show Continuation (Hidden) Signals", group=grp_div)
div_req_conf      = input.string("Any", "Signal Strength", options=["Any", "Confluence Only (R+M)"], group=grp_div)
lbL = input.int(1, "Pivot Left Strength", minval=1, group=grp_div)
lbR = input.int(3, "Pivot Right Strength", minval=1, group=grp_div)
div_style_type    = input.string("Normal", "Label Style", options=["Normal", "Subtle", "Minimal"], group=grp_div)
div_col_bull      = input.color(color.green, "Bull Color", group=grp_div)
div_col_bear      = input.color(color.red, "Bear Color", group=grp_div)
div_col_neut      = input.color(color.gray, "Non-Trend Color", group=grp_div)
div_lbl_size      = input.string("Tiny", "Text Size", options=["Tiny", "Small", "Normal"], group=grp_div)
div_rsi_len       = input.int(9, "RSI Length", minval=1, group=grp_div)
div_macd_f        = input.int(12, "MACD Fast", group=grp_div)
div_macd_s        = input.int(26, "MACD Slow", group=grp_div)
div_macd_sig      = input.int(9,  "MACD Signal", group=grp_div)
div_lookback      = input.int(75, "Max Search Range", group=grp_div)
rsi_v = ta.rsi(close, div_rsi_len)
[_, _, hist_v] = ta.macd(close, div_macd_f, div_macd_s, div_macd_sig)
rPL = ta.pivotlow(rsi_v, lbL, lbR),  rPH = ta.pivothigh(rsi_v, lbL, lbR)
hPL = ta.pivotlow(hist_v, lbL, lbR), hPH = ta.pivothigh(hist_v, lbL, lbR)
var float l_r_pl = na, var float l_p_r_pl = na, var int l_r_pl_i = na
var float l_r_ph = na, var float l_p_r_ph = na, var int l_r_ph_i = na
var float l_h_pl = na, var float l_p_h_pl = na, var int l_h_pl_i = na
var float l_h_ph = na, var float l_p_h_ph = na, var int l_h_ph_i = na
bool r_bull_r = false, bool r_bull_h = false, bool r_bear_r = false, bool r_bear_h = false
bool m_bull_r = false, bool m_bull_h = false, bool m_bear_r = false, bool m_bear_h = false
if (div_source == "RSI Only" or div_source == "Both")
    if not na(rPL)
        if not na(l_r_pl) and (bar_index - lbR - l_r_pl_i) <= div_lookback
            if low[lbR] < l_p_r_pl and rsi_v[lbR] > l_r_pl
                r_bull_r := true
            else if low[lbR] > l_p_r_pl and rsi_v[lbR] < l_r_pl
                r_bull_h := true
        l_r_pl := rsi_v[lbR], l_p_r_pl := low[lbR], l_r_pl_i := bar_index[lbR]
    if not na(rPH)
        if not na(l_r_ph) and (bar_index - lbR - l_r_ph_i) <= div_lookback
            if high[lbR] > l_p_r_ph and rsi_v[lbR] < l_r_ph
                r_bear_r := true
            else if high[lbR] < l_p_r_ph and rsi_v[lbR] > l_r_ph
                r_bear_h := true
        l_r_ph := rsi_v[lbR], l_p_r_ph := high[lbR], l_r_ph_i := bar_index[lbR]
if (div_source == "MACD Only" or div_source == "Both")
    if not na(hPL)
        if not na(l_h_pl) and (bar_index - lbR - l_h_pl_i) <= div_lookback
            if low[lbR] < l_p_h_pl and hist_v[lbR] > l_h_pl
                m_bull_r := true
            else if low[lbR] > l_p_h_pl and hist_v[lbR] < l_h_pl
                m_bull_h := true
        l_h_pl := hist_v[lbR], l_p_h_pl := low[lbR], l_h_pl_i := bar_index[lbR]
    if not na(hPH)
        if not na(l_h_ph) and (bar_index - lbR - l_h_ph_i) <= div_lookback
            if high[lbR] > l_p_h_ph and hist_v[lbR] < l_h_ph
                m_bear_r := true
            else if high[lbR] < l_p_h_ph and hist_v[lbR] > l_h_ph
                m_bear_h := true
        l_h_ph := hist_v[lbR], l_p_h_ph := high[lbR], l_h_ph_i := bar_index[lbR]
f_draw_div(is_bull, reg, hid, r_reg, r_hid, m_reg, m_hid) =>
    if show_div_engine
        v_hid = hid and div_allow_hidden
        v_reg = reg
        is_trend = is_bull ? (smc_trend == 1) : (smc_trend == -1)
        mode_pass = (div_logic_mode == "Both") or (div_logic_mode == "Trend Only" and is_trend) or (div_logic_mode == "Reversal Only" and not is_trend)
        is_conf = (r_reg or r_hid) and (m_reg or m_hid)
        str_pass = (div_req_conf == "Any") or (div_req_conf == "Confluence Only (R+M)" and is_conf)
        if mode_pass and str_pass and (v_reg or v_hid)
            sz   = div_lbl_size == "Tiny" ? size.tiny : div_lbl_size == "Small" ? size.small : size.normal
            c    = is_trend ? (is_bull ? div_col_bull : div_col_bear) : div_col_neut
            string reg_arrow = is_bull ? "↑" : "↓"
            string hid_arrow = is_bull ? "⇗" : "⇘"
            string t = ""
            if (r_reg or m_reg) and v_reg
                t += (r_reg and m_reg ? "RM" : r_reg ? "R" : "M") + reg_arrow + " "
            if (r_hid or m_hid) and v_hid
                t += (r_hid and m_hid ? "RM" : r_hid ? "R" : "M") + hid_arrow
            if t != "" and div_style_type != "Minimal"
                label.new(bar_index[lbR], is_bull ? low[lbR] - d_offset3 : high[lbR] + d_offset3, t, 
                  style=is_bull ? label.style_label_up : label.style_label_down,
                  color=color.new(c, 85), textcolor=color.new(c, 0), size=sz)
            else if t != ""
                label.new(bar_index[lbR], is_bull ? low[lbR] - d_offset3 : high[lbR] + d_offset3, is_bull ? "▲" : "▼", 
                  style=label.style_none, textcolor=color.new(c, 0), size=sz)
f_draw_div(true, r_bull_r or m_bull_r, r_bull_h or m_bull_h, r_bull_r, r_bull_h, m_bull_r, m_bull_h)
f_draw_div(false, r_bear_r or m_bear_r, r_bear_h or m_bear_h, r_bear_r, r_bear_h, m_bear_r, m_bear_h)

// -------------------- #12 GAP STRATEGY (TOUCHLESS EMA + LEGACY FEATURES) --------------------
grp_gap = "空 Gap Strategy Settings"
show_gap_vis     = input.bool(true, "Show Gap Strategy Visuals (Master Toggle)", group=grp_gap)
show_gap_labels  = input.bool(true, "Show Signal Labels", group=grp_gap) 
gap_lbl_size     = input.string("Tiny", "Signal Label Size", options=["Tiny", "Small", "Normal", "Huge"], group=grp_gap)
gap_trade_dir    = input.string("Both", "Trade Direction", options=["Both", "Long Only", "Short Only"], group=grp_gap)
show_gap_lines   = input.bool(true, "Show Trade Step-Lines", group=grp_gap)
c_gap_ent        = input.color(color.blue, "Avg Entry Line Color", group=grp_gap)
c_gap_sl         = input.color(color.red, "SL Line Color", group=grp_gap)
c_gap_tp         = input.color(color.lime, "TP Line Color", group=grp_gap)
g_size = gap_lbl_size == "Tiny" ? size.tiny : gap_lbl_size == "Small" ? size.small : gap_lbl_size == "Normal" ? size.normal : size.huge
var float t_ent = na, var float t_sl = na, var float t_tp = na
var float t_risk = 0.0, var string t_dir = "", var bool t_active = false
var float pos_size = 0.0, var float g_next_ptp_price = na, var int g_ptp_count = 0
var label g_pot_lbl = na
pot_long  = (st_dir < 0) and (high < extra_ema) and (open < extra_ema) and (close < extra_ema) and (low < extra_ema) and (gap_trade_dir != "Short Only")
pot_short = (st_dir > 0) and (low > extra_ema) and (open > extra_ema) and (close > extra_ema) and (high > extra_ema) and (gap_trade_dir != "Long Only")
if (pot_long or pot_short) and not t_active and show_gap_vis and show_gap_labels
    label.delete(g_pot_lbl)
    g_pot_lbl := label.new(bar_index, pot_long ? low - d_offset2 : high + d_offset2, "POTENTIAL", 
          color=color.new(color.gray, 85), textcolor=color.white, 
          style=pot_long ? label.style_label_up : label.style_label_down, size=size.tiny)
else
    label.delete(g_pot_lbl)
var float g_pend_ent = na
var float g_pend_sl  = na
var int g_pend_idx   = -1
is_gap_candle_long  = (st_dir < 0) and (high < extra_ema) and (open < extra_ema) and (close < extra_ema) and (low < extra_ema)
is_gap_candle_short = (st_dir > 0) and (low > extra_ema) and (open > extra_ema) and (close > extra_ema) and (high > extra_ema)
if not t_active
    if is_gap_candle_long[1] and high > high[1] and not force_close
        t_active := true, t_dir := "LONG", pos_size := 1.0
        t_ent := high[1], t_sl := low[1], t_risk := math.abs(t_ent - t_sl)
        t_tp := t_ent + (t_risk * 2), g_next_ptp_price := t_ent + t_risk, g_ptp_count := 0
        if show_gap_vis and show_gap_labels
            label.new(bar_index, low - d_offset, "Ema BUY Entry", color=color.new(color.gray, 85), textcolor=color.white, style=label.style_label_up, size=g_size)
    else if is_gap_candle_short[1] and low < low[1] and not force_close
        t_active := true, t_dir := "SHORT", pos_size := 1.0
        t_ent := low[1], t_sl := high[1], t_risk := math.abs(t_ent - t_sl)
        t_tp := t_ent - (t_risk * 2), g_next_ptp_price := t_ent - t_risk, g_ptp_count := 0
        if show_gap_vis and show_gap_labels
            label.new(bar_index, high + d_offset, "Ema SELL Entry", color=color.new(color.gray, 85), textcolor=color.white, style=label.style_label_down, size=g_size)
else 
    if (t_dir == "LONG" and is_gap_candle_long) or (t_dir == "SHORT" and is_gap_candle_short)
        g_pend_ent := t_dir == "LONG" ? high : low
        g_pend_sl  := t_dir == "LONG" ? low  : high
        g_pend_idx := bar_index
    trigger_avg = bar_index == g_pend_idx + 1 and ((t_dir == "LONG" and high > g_pend_ent) or (t_dir == "SHORT" and low < g_pend_ent)) and not force_close
    if trigger_avg and not force_close
        float old_sl = t_sl 
        t_ent := ((t_ent * pos_size) + close) / (pos_size + 1)
        pos_size += 1.0
        t_sl := g_pend_sl 
        float sl_shift = math.abs(t_sl - old_sl)
        if t_dir == "LONG"
            t_tp += sl_shift
        else
            t_tp -= sl_shift
        g_next_ptp_price := t_dir == "LONG" ? close + t_risk : close - t_risk
        g_ptp_count := 0 
        if show_gap_vis and show_gap_labels
            label.new(bar_index, t_dir == "LONG" ? low - d_offset2 : high + d_offset2, "Ema Avg #" + str.tostring(pos_size, "#"), color=color.new(color.gray, 85), textcolor=color.white, style=t_dir == "LONG" ? label.style_label_up : label.style_label_down, size=g_size)
        g_pend_ent := na
if t_active and g_ptp_count == 0
    ptp_hit = (t_dir == "LONG" and high >= g_next_ptp_price) or (t_dir == "SHORT" and low <= g_next_ptp_price)
    if ptp_hit
        g_ptp_count := 1
        if show_gap_vis and show_gap_labels
            label.new(bar_index, t_dir == "LONG" ? high + d_offset2 : low - d_offset2, "Ema P~TP", color=color.new(color.lime, 85), textcolor=color.lime, style=t_dir == "LONG" ? label.style_label_down : label.style_label_up, size=g_size)
if t_active
    if t_dir == "LONG" and st_val > t_sl
        float move_amt = st_val - t_sl
        t_sl := st_val
        t_tp += move_amt 
    else if t_dir == "SHORT" and st_val < t_sl
        float move_amt = t_sl - st_val
        t_sl := st_val
        t_tp -= move_amt 
if t_active
    sl_hit = (t_dir == "LONG" and low < t_sl) or (t_dir == "SHORT" and high > t_sl)
    tp_hit = (t_dir == "LONG" and high >= t_tp) or (t_dir == "SHORT" and low <= t_tp)
    trend_flip = (t_dir == "LONG" and st_dir > 0) or (t_dir == "SHORT" and st_dir < 0)
    if sl_hit or tp_hit or trend_flip or force_close
        if show_gap_vis and show_gap_labels
            string ex_txt = tp_hit ? "Ema TP" : sl_hit ? (g_ptp_count > 0 ? "Ema T~SL" : "Ema SL") : "Ema Eod EXIT"
            color ex_col = tp_hit ? color.green : color.red
            label.new(bar_index, t_dir == "LONG" ? low - d_offset2 : high + d_offset2, ex_txt, color=color.new(ex_col, 85), textcolor=ex_col, style=t_dir == "LONG" ? label.style_label_up : label.style_label_down, size=g_size)
        t_active := false, t_ent := na, t_sl := na, t_tp := na, pos_size := 0.0, g_ptp_count := 0
gap_plot_allowed = show_gap_vis and show_gap_lines and t_active
plot(gap_plot_allowed ? t_ent : na, "Gap Entry", color=c_gap_ent, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(gap_plot_allowed ? t_tp : na, "Gap TP", color=c_gap_tp, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(gap_plot_allowed ? t_sl : na, "Gap SL", color=c_gap_sl, style=plot.style_linebr, linestyle=plot.linestyle_dashed)

// -------------------- #13 DIV TRACE STRATEGY --------------------
grp_dt   = "云迹 Div Trace Strategy"
show_dt_vis    = input.bool(true, "Show Div Trace Strategy Visuals (Master)", group=grp_dt)
show_dt_labels = input.bool(true, "Show Signal Labels", group=grp_dt) 
dt_lbl_sz      = input.string("Tiny", "Signal Label Size", options=["Tiny", "Small", "Normal", "Huge"], group=grp_dt)
dt_trade_dir   = input.string("Both", "Trade Direction", options=["Both", "Long Only", "Short Only"], group=grp_dt)
show_dt_lines  = input.bool(true, "Show Trade Step-Lines", group=grp_dt)
c_ent_line     = input.color(color.blue, "Avg Entry Line Color", group=grp_dt)
c_sl_line      = input.color(color.red, "SL Line Color", group=grp_dt)
c_tp_line      = input.color(color.lime, "TP Line Color", group=grp_dt)
dt_sz         = dt_lbl_sz == "Tiny" ? size.tiny : dt_lbl_sz == "Small" ? size.small : dt_lbl_sz == "Normal" ? size.normal : size.huge
dt_bull_div   = r_bull_r or r_bull_h or m_bull_r or m_bull_h
dt_bear_div   = r_bear_r or r_bear_h or m_bear_r or m_bear_h
dt_c_low      = math.min(ema_f, ema_s), dt_c_high = math.max(ema_f, ema_s)
dt_buy_sig    = dt_allowed and (dt_trade_dir != "Short Only") and (st_dir < 0) and (ema_f > ema_s) and dt_bull_div and low[lbR] > dt_c_low[lbR]
dt_sell_sig   = dt_allowed and (dt_trade_dir != "Long Only") and (st_dir > 0) and (ema_f < ema_s) and dt_bear_div and high[lbR] < dt_c_high[lbR]
var float d_avg   = na
var float d_sl    = na
var float d_tp    = na
var float d_units = 0.0
var float d_risk  = 0.0 
var float d_static_ptp1 = na
var float d_static_ptp2 = na
var string d_side = ""
var bool d_ptp1_hit = false
var bool d_ptp2_hit = false
if d_units == 0
    if dt_buy_sig or dt_sell_sig
        d_side     := dt_buy_sig ? "LONG" : "SHORT"
        d_units    := 1.0
        d_ptp1_hit := false, d_ptp2_hit := false
        d_avg      := close
        float closer_val = d_side == "LONG" ? math.max(dt_c_low[lbR], st_val[lbR]) : math.min(dt_c_high[lbR], st_val[lbR])
        d_sl := closer_val
        d_risk := math.abs(d_avg - d_sl)
        d_static_ptp1 := d_side == "LONG" ? d_avg + d_risk : d_avg - d_risk
        d_static_ptp2 := d_side == "LONG" ? d_avg + (d_risk * 2) : d_avg - (d_risk * 2)
        d_tp           := d_static_ptp2  
        if show_dt_vis and show_dt_labels
            string entry_text = d_side == "LONG" ? "Div Buy Entry" : "Div Sell Entry"
            label.new(bar_index, d_side == "LONG" ? low - d_offset : high + d_offset, entry_text, yloc=yloc.price, color=color.new(color.gray, 85), textcolor=color.white, style=d_side == "LONG" ? label.style_label_up : label.style_label_down, size=dt_sz)
else
    if (d_side == "LONG" and dt_buy_sig) or (d_side == "SHORT" and dt_sell_sig)
        float old_sl = d_sl 
        d_avg   := ((d_avg * d_units) + close) / (d_units + 1)
        d_units += 1.0
        float farther_val = d_side == "LONG" ? math.min(dt_c_low[lbR], st_val[lbR]) : math.max(dt_c_high[lbR], st_val[lbR])
        d_sl := d_side == "LONG" ? math.max(d_sl, farther_val) : math.min(d_sl, farther_val)
        float sl_shift = math.abs(d_sl - old_sl)
        if d_side == "LONG"
            d_tp += sl_shift
        else
            d_tp -= sl_shift
        if show_dt_vis and show_dt_labels
            label.new(bar_index, d_side == "LONG" ? low - d_offset : high + d_offset, "Div Avg #" + str.tostring(d_units, "#"), yloc=yloc.price, color=color.new(color.gray, 85), textcolor=color.white, style=d_side == "LONG" ? label.style_label_up : label.style_label_down, size=dt_sz)
bool h_sl = (d_side == "LONG" and low <= d_sl) or (d_side == "SHORT" and high >= d_sl)
bool h_tp = (d_side == "LONG" and high >= d_tp) or (d_side == "SHORT" and low <= d_tp)
bool hit_p1 = show_dt_vis and d_units > 0 and not d_ptp1_hit and ((d_side == "LONG" and high >= d_static_ptp1) or (d_side == "SHORT" and low <= d_static_ptp1))
bool hit_p2 = show_dt_vis and d_units > 0 and not d_ptp2_hit and ((d_side == "LONG" and high >= d_static_ptp2) or (d_side == "SHORT" and low <= d_static_ptp2))
if d_units > 0
    if hit_p1
        d_ptp1_hit := true
        if show_dt_vis and show_dt_labels
            label.new(bar_index, d_side == "LONG" ? high + d_offset : low - d_offset, "Div P~TP1", yloc=yloc.price, color=color.new(color.lime, 85), textcolor=color.lime, style=d_side == "LONG" ? label.style_label_down : label.style_label_up, size=dt_sz)
    if hit_p2
        d_ptp2_hit := true
        if show_dt_vis and show_dt_labels
            label.new(bar_index, d_side == "LONG" ? high + d_offset : low - d_offset, "Div P~TP2", yloc=yloc.price, color=color.new(color.lime, 85), textcolor=color.lime, style=d_side == "LONG" ? label.style_label_down : label.style_label_up, size=dt_sz)
    if h_sl or h_tp or force_close
        if show_dt_vis and show_dt_labels
            string exit_txt = h_sl ? ((d_ptp1_hit or d_ptp2_hit) ? "Div T~SL" : "Div SL EXIT") : h_tp ? "Div TP EXIT" : "Div EOD EXIT"
            color exit_col = force_close ? (((d_side == "LONG" and close > d_avg) or (d_side == "SHORT" and close < d_avg)) ? color.green : color.red) : (h_sl ? color.red : color.green)
            label.new(bar_index, d_side == "LONG" ? low - d_offset : high + d_offset, exit_txt, yloc=yloc.price, color=color.new(exit_col, 85), textcolor=exit_col, style=d_side == "LONG" ? label.style_label_up : label.style_label_down, size=dt_sz)
        d_units := 0.0, d_side := "", d_avg := na, d_tp := na, d_sl := na, d_ptp1_hit := false, d_ptp2_hit := false
plot_allowed = show_dt_vis and show_dt_lines and d_units > 0
plot(plot_allowed ? d_avg : na, "Div Avg Entry", color=c_ent_line, linewidth=1, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(plot_allowed ? d_tp : na, "Div Take Profit", color=c_tp_line, linewidth=1, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(plot_allowed ? d_sl : na, "Div Stop Loss", color=c_sl_line, linewidth=1, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
if d_units == 0
    d_static_ptp1  := na
    d_static_ptp2  := na
    d_side         := ""
    d_ptp1_hit     := false
    d_ptp2_hit     := false

// -------------------- #13.5 NEW: 1-MIN OPENING RANGE STRATEGY --------------------
grp_om = "⏱️ 1-Min Opening Range Strategy"
show_om_vis     = input.bool(true, "Enable Strategy (Master Toggle)", group=grp_om)
show_om_labels  = input.bool(true, "Show Signal Labels", group=grp_om)
om_lbl_size     = input.string("Tiny", "Signal Label Size", options=["Tiny", "Small", "Normal", "Huge"], group=grp_om)
om_rr_ratio     = input.float(2.0, "Risk-to-Reward Ratio (1:X)", minval=0.5, step=0.1, group=grp_om)
c_om_ent        = input.color(color.blue, "Entry Line Color", group=grp_om)
c_om_sl         = input.color(color.red, "SL Line Color", group=grp_om)
c_om_tp         = input.color(color.lime, "TP Line Color", group=grp_om)

// 1. Opening Candle Size Filter Inputs
use_size_filter = input.bool(true, "Enable Opening Candle Size Filter", group=grp_om)
min_candle_pct  = input.float(0.05, "Minimum Opening Candle Size (%)", minval=0.0, step=0.01, group=grp_om)
max_candle_pct  = input.float(0.20, "Maximum Opening Candle Size (%)", minval=0.0, step=0.01, group=grp_om)

// 2. Configurable Pullback Level Input (Calculated from combined range of first 2 candles)
om_pb_pct       = input.float(50.0, "Pullback Entry Level (%)", minval=0.01, maxval=99.99, step=0.5, group=grp_om)

// Global Timeframe Guard: Only calculates if chart is explicitly 1-Minute
is_chart_1m = timeframe.isintraday and timeframe.multiplier == 1

// Engine Tracking States
var float  om_entry_target = na
var float  om_sl_target    = na
var int    om_setup_idx    = -1
var bool   om_setup_valid  = false
var string om_setup_dir    = ""
var bool   om_traded_today = false

var bool  om_active = false
var float om_ent    = na
var float om_sl     = na
var float om_tp     = na

// Dynamic Size Mapping
om_sz = om_lbl_size == "Tiny" ? size.tiny : om_lbl_size == "Small" ? size.small : om_lbl_size == "Normal" ? size.normal : size.huge

if is_chart_1m and show_om_vis
    // Reset daily trade and tracking states on the first candle of a new session
    if is_first_candle
        om_traded_today := false
        om_setup_valid  := false
        om_setup_dir    := ""
        om_active       := false
        om_ent          := na
        om_sl           := na
        om_tp           := na
        om_setup_idx    := bar_index

    // Check Candle 1 and Candle 2 states sequentially
    if om_setup_idx != -1
        // Validate at the close of the second candle (1 bar after the opening candle)
        if bar_index == om_setup_idx + 1
            bool c1_green = close[1] > open[1]
            bool c1_red   = close[1] < open[1]
            bool c2_green = close > open
            bool c2_red   = close < open
            
            // Check size filter on the very first opening candle
            opening_range_pct = ((high[1] - low[1]) / open[1]) * 100.0
            size_filter_passed = true
            if use_size_filter
                if (opening_range_pct < min_candle_pct) or (opening_range_pct > max_candle_pct)
                    size_filter_passed := false

            if size_filter_passed
                float comb_high = math.max(high, high[1])
                float comb_low  = math.min(low, low[1])
                float comb_rng  = comb_high - comb_low

                if c1_green and c2_green
                    om_setup_dir    := "LONG"
                    om_entry_target := comb_high - (comb_rng * (om_pb_pct / 100.0))
                    om_sl_target    := comb_low
                    om_setup_valid  := true
                    
                else if c1_red and c2_red
                    om_setup_dir    := "SHORT"
                    om_entry_target := comb_low + (comb_rng * (om_pb_pct / 100.0))
                    om_sl_target    := comb_high
                    om_setup_valid  := true
                else
                    om_setup_valid  := false
            else
                om_setup_valid := false

        // Execute Pullback Entry strictly on the Third Candle (2 bars after the opening candle)
        if bar_index == om_setup_idx + 2 and om_setup_valid and not om_traded_today and not om_active
            if om_setup_dir == "LONG" and (low <= om_entry_target)
                om_active       := true
                om_traded_today := true
                om_ent          := om_entry_target
                om_sl           := om_sl_target
                float risk      = math.abs(om_ent - om_sl)
                om_tp           := om_ent + (risk * om_rr_ratio)
                
                if show_om_labels
                    label.new(bar_index, low - d_offset, "1m OR Long Pullback", color=color.new(color.blue, 85), textcolor=color.white, style=label.style_label_up, size=om_sz)
                    
            else if om_setup_dir == "SHORT" and (high >= om_entry_target)
                om_active       := true
                om_traded_today := true
                om_ent          := om_entry_target
                om_sl           := om_sl_target
                float risk      = math.abs(om_ent - om_sl)
                om_tp           := om_ent - (risk * om_rr_ratio)
                
                if show_om_labels
                    label.new(bar_index, high + d_offset, "1m OR Short Pullback", color=color.new(color.purple, 85), textcolor=color.white, style=label.style_label_down, size=om_sz)

    // Manage Position Tracking
    if om_active
        om_sl_hit = (om_setup_dir == "LONG" and low <= om_sl) or (om_setup_dir == "SHORT" and high >= om_sl)
        om_tp_hit = (om_setup_dir == "LONG" and high >= om_tp) or (om_setup_dir == "SHORT" and low <= om_tp)
        
        if om_sl_hit or om_tp_hit
            if show_om_labels
                string ex_txt = om_tp_hit ? "1m OR TP" : "1m OR SL"
                color ex_col  = om_tp_hit ? color.green : color.red
                label.new(bar_index, om_tp_hit ? high + d_offset : low - d_offset, ex_txt, color=color.new(ex_col, 85), textcolor=ex_col, style=om_tp_hit ? label.style_label_down : label.style_label_up, size=om_sz)
            om_active      := false
            om_ent         := na
            om_sl          := na
            om_tp          := na
            om_setup_valid := false

// Step Line Plots matching other styles
om_plot_ready = show_om_vis and is_chart_1m and om_active
plot(om_plot_ready ? om_ent : na, "1m OR Entry Line", color=c_om_ent, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(om_plot_ready ? om_tp : na, "1m OR TP Line", color=c_om_tp, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
plot(om_plot_ready ? om_sl : na, "1m OR SL Line", color=c_om_sl, style=plot.style_linebr, linestyle=plot.linestyle_dashed)
// -------------------- #14 DASHBOARD (DYNAMIC MILESTONE RATCHET) ----------------------------------------------------------------------------------------------------------------
grp_dash = "表 Dashboard Settings"
show_dash       = input.bool(true, "Show Dashboard", group=grp_dash)
dash_pos        = input.string("Top Right", "Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"], group=grp_dash)
dash_size       = input.string("Normal", "Table Size", options=["Tiny", "Small", "Normal"], group=grp_dash)
show_m_active   = input.bool(true, "Metric: Active Trade Info", group=grp_dash)
show_m_trades   = input.bool(true, "Metric: Trades Today (W:L=T)", group=grp_dash)
show_m_rolling  = input.bool(true, "Metric: Rolling Win% (Master Strategy)", group=grp_dash)
show_m_today_r  = input.bool(true, "Metric: Daily Net Pts", group=grp_dash)
show_m_state    = input.bool(true, "Metric: Market State", group=grp_dash)
show_m_conf     = input.bool(true, "Metric: SMC Confidence", group=grp_dash)
show_m_mtf      = input.bool(true, "Metric: MTF Alignment", group=grp_dash)
htf_res         = input.timeframe("15", "HTF Timeframe (for MTF Check)", group=grp_dash)
show_m_vprox    = input.bool(true, "Metric: VWAP Proximity", group=grp_dash)
show_m_sqz      = input.bool(true, "Metric: Squeeze Status", group=grp_dash)
show_m_adx      = input.bool(true, "Metric: ADX Power", group=grp_dash)
show_m_rsi      = input.bool(true, "Metric: RSI Heat", group=grp_dash)
show_m_vol      = input.bool(true, "Metric: Volume Expansion", group=grp_dash)
var float d_pos_pts = 0.0, var float d_neg_pts = 0.0
var int d_wins = 0, var int d_losses = 0
var float m_pos_pts = 0.0, var float m_neg_pts = 0.0
var int m_wins = 0, var int m_losses = 0
var trade_high_water = 0.0
var win_history = array.new_float(0)
int max_window  = 100
string active_master = show_gap_vis and not show_dt_vis ? "Hammer" : not show_gap_vis and show_dt_vis ? "Scalpel" : "Dual"
if ta.change(time("D")) != 0
    d_pos_pts := 0.0, d_neg_pts := 0.0, d_wins := 0, d_losses := 0
if ta.change(time("M")) != 0
    m_pos_pts := 0.0, m_neg_pts := 0.0, m_wins := 0, m_losses := 0
trade_active = (show_gap_vis and t_active) or (show_dt_vis and d_units > 0)
if trade_active
    float current_reach = 0.0
    if (show_gap_vis and t_active)
        current_reach := t_dir == "LONG" ? (high - t_ent) : (t_ent - low)
    else if (show_dt_vis and d_units > 0)
        current_reach := d_side == "LONG" ? (high - d_avg) : (d_avg - low)
    trade_high_water := math.max(trade_high_water, current_reach)
gap_just_closed = show_gap_vis and t_active[1] and not t_active
div_just_closed = show_dt_vis and d_units[1] > 0 and d_units == 0
master_closed   = (show_gap_vis and not show_dt_vis and gap_just_closed) or (show_dt_vis and not show_gap_vis and div_just_closed) or (show_gap_vis and show_dt_vis and (gap_just_closed or div_just_closed))
if gap_just_closed or div_just_closed
    float final_trade_pts = 0.0
    bool is_win = false
    float s_ent = gap_just_closed ? t_ent[1] : d_avg[1]
    float s_tp  = gap_just_closed ? t_tp[1]  : d_tp[1]
    float s_ptp = gap_just_closed ? g_next_ptp_price[1] : (d_ptp2_hit[1] ? d_static_ptp2[1] : d_static_ptp1[1])
    bool s_ptp_hit = gap_just_closed ? (g_ptp_count[1] > 0) : (d_ptp1_hit[1] or d_ptp2_hit[1])
    if trade_high_water >= math.abs(s_tp - s_ent)
        final_trade_pts := math.abs(s_tp - s_ent)
        is_win := true
    else if s_ptp_hit
        final_trade_pts := math.abs(s_ptp - s_ent)
        is_win := true
    else
        final_trade_pts := math.abs(close - s_ent) 
        is_win := false
    if is_win
        d_pos_pts += final_trade_pts, m_pos_pts += final_trade_pts
        d_wins += 1, m_wins += 1
        if master_closed
            array.push(win_history, 1.0)
    else
        d_neg_pts += final_trade_pts, m_neg_pts += final_trade_pts
        d_losses += 1, m_losses += 1
        if master_closed
            array.push(win_history, 0.0)
    trade_high_water := 0.0
    if array.size(win_history) > max_window
        array.remove(win_history, 0)
is_high_tf = timeframe.isintraday == false or timeframe.multiplier > 60
string stat_header = is_high_tf ? "Month Stats" : "Today Stats"
float cur_pos   = is_high_tf ? m_pos_pts : d_pos_pts
float cur_neg   = is_high_tf ? m_neg_pts : d_neg_pts
int cur_w       = is_high_tf ? m_wins : d_wins
int cur_l       = is_high_tf ? m_losses : d_losses
int cur_total   = cur_w + cur_l
float cur_net   = cur_pos - cur_neg
float cur_wr    = cur_total > 0 ? (float(cur_w) / float(cur_total)) * 100 : 0
float rolling_wr = array.size(win_history) > 0 ? (array.sum(win_history) / array.size(win_history)) * 100 : 0.0
d_bb_bw = bb_mid != 0 ? (bb_up - bb_low) / bb_mid : 0
d_is_squeeze = d_bb_bw <= ta.lowest(d_bb_bw, 100)
[_, _, d_adx_val] = ta.dmi(14, 14)
v_prox_pc = not na(v_val) ? ((close - v_val) / v_val) * 100 : 0.0
htf_trend_v = request.security(syminfo.tickerid, htf_res, smc_trend, lookahead=barmerge.lookahead_off)
mtf_aligned = (smc_trend != 0 and smc_trend == htf_trend_v)
var float smc_score = 0.0
smc_score := 0.0  
if smc_trend != 0 
    smc_score += 30
if mtf_aligned 
    smc_score += 40
if d_adx_val > 25 
    smc_score += 30
string conf_label = smc_score >= 100 ? "ELITE" : smc_score >= 70 ? "STRONG" : smc_score >= 40 ? "DECENT" : "WEAK"
color conf_color = smc_score >= 70 ? color.teal : smc_score >= 40 ? color.orange : color.maroon
vol_exp = volume > ta.sma(volume, 20) * 1.5
int n_rows = 1 
n_rows += (show_m_active ? 4 : 0)
n_rows += (show_m_trades ? 1 : 0)
n_rows += (show_m_rolling ? 1 : 0)
n_rows += (show_m_today_r ? 1 : 0)
n_rows += (show_m_state ? 1 : 0)
n_rows += (show_m_conf ? 1 : 0)
n_rows += (show_m_mtf ? 1 : 0)
n_rows += (show_m_vprox ? 1 : 0)
n_rows += (show_m_sqz ? 1 : 0)
n_rows += (show_m_adx ? 1 : 0)
n_rows += (show_m_rsi ? 1 : 0)
n_rows += (show_m_vol ? 1 : 0)
m_txt = d_adx_val > 25 and not d_is_squeeze ? "TREND" : d_adx_val < 20 or d_is_squeeze ? "RANGE" : "TRANSIT"
color state_col = m_txt == "TREND" ? color.blue : m_txt == "RANGE" ? color.orange : color.purple
color v_col = math.abs(v_prox_pc) > 1.5 ? color.red : math.abs(v_prox_pc) > 0.7 ? color.orange : color.teal
var table d_tab = na
t_pos = dash_pos == "Top Right" ? position.top_right : dash_pos == "Bottom Right" ? position.bottom_right : dash_pos == "Top Left" ? position.top_left : position.bottom_left
t_size = dash_size == "Tiny" ? size.tiny : dash_size == "Small" ? size.small : size.normal
if (n_rows != n_rows[1] or dash_pos != dash_pos[1] or dash_size != dash_size[1]) and not na(d_tab)
    table.delete(d_tab), d_tab := na
if show_dash and na(d_tab)
    d_tab := table.new(t_pos, 2, n_rows, bgcolor=color.new(color.black, 50), border_width=1, border_color=color.gray)
if show_dash and barstate.islast
    table.clear(d_tab, 0, 0, 1, n_rows - 1)
    table.cell(d_tab, 0, 0, "Metric", text_color=color.white, bgcolor=color.new(color.blue, 60), text_size=t_size)
    table.cell(d_tab, 1, 0, "Status", text_color=color.white, bgcolor=color.new(color.blue, 60), text_size=t_size)
    int r = 1
    if show_m_active
        bool gap_on = show_gap_vis and t_active and not force_close
        bool div_on = show_dt_vis and d_units > 0 and not force_close
        bool om_on  = show_om_vis and is_chart_1m and om_active
        string side_txt = (gap_on ? "GAP:" + t_dir : "") + (div_on ? " DIV:" + d_side : "") + (om_on ? " 1mOR:LONG" : "")
        if side_txt == "" or side_txt == " "
            side_txt := "NONE"
        color side_col = om_on ? color.teal : gap_on or div_on ? color.purple : color.gray
        table.cell(d_tab, 0, r, "Active Side", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, side_txt, bgcolor=side_col, text_color=color.white, text_size=t_size), r += 1
        if gap_on or div_on or om_on
            table.cell(d_tab, 0, r, "Avg Entry", text_color=color.white, text_size=t_size)
            table.cell(d_tab, 1, r, (gap_on ? "G:" + str.tostring(t_ent, "#.##") : "") + (div_on ? " D:" + str.tostring(d_avg, "#.##") : "") + (om_on ? " 1m:" + str.tostring(om_ent, "#.##") : ""), text_color=color.white, text_size=t_size), r += 1
            table.cell(d_tab, 0, r, "Stop Loss", text_color=color.white, text_size=t_size)
            table.cell(d_tab, 1, r, (gap_on ? "G:" + str.tostring(t_sl, "#.##") : "") + (div_on ? " D:" + str.tostring(d_sl, "#.##") : "") + (om_on ? " 1m:" + str.tostring(om_sl, "#.##") : ""), text_color=color.orange, text_size=t_size), r += 1
            table.cell(d_tab, 0, r, "Take Profit", text_color=color.white, text_size=t_size)
            table.cell(d_tab, 1, r, (gap_on ? "G:" + str.tostring(t_tp, "#.##") : "") + (div_on ? " D:" + str.tostring(d_tp, "#.##") : "") + (om_on ? " 1m:" + str.tostring(om_tp, "#.##") : ""), text_color=color.lime, text_size=t_size), r += 1
        else
            r += 3
    if show_m_trades
        color w_col = cur_net > 0 ? color.lime : cur_net < 0 ? color.red : color.white
        table.cell(d_tab, 0, r, stat_header, text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, "T=" + str.tostring(cur_total) + " (" + str.tostring(cur_w) + ":" + str.tostring(cur_l) + ") " + str.tostring(cur_wr, "#") + "%", text_color=w_col, text_size=t_size), r += 1
    if show_m_rolling
        color r_wr_c = rolling_wr >= 60 ? color.lime : rolling_wr >= 45 ? color.orange : color.red
        table.cell(d_tab, 0, r, "Win% (" + active_master + ")", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, str.tostring(rolling_wr, "#.#") + "% [" + str.tostring(array.size(win_history)) + "]", bgcolor=color.new(r_wr_c, 40), text_color=color.white, text_size=t_size), r += 1
    if show_m_today_r
        string formula = "(" + str.tostring(cur_pos, "#") + "-" + str.tostring(cur_neg, "#") + "=" + str.tostring(cur_net, "#") + "Pts)"
        table.cell(d_tab, 0, r, "Captured Pts", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, formula, bgcolor=cur_net >= 0 ? color.new(color.green, 40) : color.new(color.red, 40), text_color=color.white, text_size=t_size), r += 1
    if show_m_state
        table.cell(d_tab, 0, r, "Market State", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, m_txt, bgcolor=color.new(state_col, 50), text_color=color.white, text_size=t_size), r += 1
    if show_m_vprox
        table.cell(d_tab, 0, r, "VWAP Prox %", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, str.tostring(v_prox_pc, "#.##") + "%", bgcolor=color.new(v_col, 50), text_color=color.white, text_size=t_size), r += 1
    if show_m_conf
        table.cell(d_tab, 0, r, "SMC Score", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, str.tostring(smc_score, "#") + " [" + conf_label + "]", bgcolor=color.new(conf_color, 50), text_color=color.white, text_size=t_size), r += 1
    if show_m_mtf
        table.cell(d_tab, 0, r, "MTF (" + htf_res + ")", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, mtf_aligned ? "ALIGNED" : "DIVERGENT", bgcolor=mtf_aligned ? color.teal : color.maroon, text_color=color.white, text_size=t_size), r += 1
    if show_m_sqz
        table.cell(d_tab, 0, r, "Squeeze", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, d_is_squeeze ? "SQUEEZING" : "NORMAL", bgcolor=d_is_squeeze ? color.orange : na, text_color=color.white, text_size=t_size), r += 1
    if show_m_adx
        table.cell(d_tab, 0, r, "ADX (14)", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, str.tostring(d_adx_val, "#.#"), bgcolor=d_adx_val > 25 ? color.purple : na, text_color=color.white, text_size=t_size), r += 1
    if show_m_rsi
        table.cell(d_tab, 0, r, "RSI Heat", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, str.tostring(rsi_v, "#.#"), bgcolor=rsi_v > 70 ? color.maroon : rsi_v < 30 ? color.teal : na, text_color=color.white, text_size=t_size), r += 1
    if show_m_vol
        table.cell(d_tab, 0, r, "Vol Expand", text_color=color.white, text_size=t_size)
        table.cell(d_tab, 1, r, vol_exp ? "HIGH" : "NORMAL", bgcolor=vol_exp ? color.purple : na, text_color=color.white, text_size=t_size), r += 1

// -------------------- #15 ALERT SYSTEM ------------------------------------------------------------------------------------------------------------------------------------------
gap_entered  = t_active and not t_active[1]
gap_averaged = t_active and pos_size > pos_size[1]
gap_closed   = not t_active and t_active[1]
if gap_entered
    alert("🚀 GAP ENTRY TRIGGERED [" + t_dir + "]\nEntry: " + str.tostring(t_ent) + "\nSL: " + str.tostring(t_sl) + "\nTP: " + str.tostring(t_tp), alert.freq_once_per_bar)
if gap_averaged
    alert("➕ GAP AVG TRIGGERED #" + str.tostring(pos_size) + "\nNew Avg Entry: " + str.tostring(t_ent) + "\nNew SL: " + str.tostring(t_sl), alert.freq_once_per_bar)
if gap_closed
    string result_label = t_milestone_hit[1] ? "WIN (Target Hit)" : "LOSS (SL Hit)"
    float final_pts     = t_milestone_hit[1] ? t_locked_pts[1] : math.abs(close - t_ent[1])
    alert("🏁 GAP TRADE CLOSED\nResult: " + result_label + "\nPoints: " + str.tostring(final_pts, "#.##") + "\nExit Price: " + str.tostring(close), alert.freq_once_per_bar)

div_entered = d_units > 0 and d_units[1] == 0
div_closed  = d_units == 0 and d_units[1] > 0
if div_entered
    alert("📉 DIV ENTRY TRIGGERED [" + d_side + "]\nEntry: " + str.tostring(d_avg) + "\nSL: " + str.tostring(d_sl) + "\nTP: " + str.tostring(d_tp), alert.freq_once_per_bar)
if div_closed
    string result_label = t_milestone_hit[1] ? "WIN (Target Hit)" : "LOSS (SL Hit)"
    float final_pts     = t_milestone_hit[1] ? t_locked_pts[1] : math.abs(close - d_avg[1])
    alert("🏁 DIV TRADE CLOSED\nResult: " + result_label + "\nPoints: " + str.tostring(final_pts, "#.##") + "\nExit Price: " + str.tostring(close), alert.freq_once_per_bar)

gap_ptp_hit = t_active and g_ptp_count > g_ptp_count[1]
div_ptp_hit = d_units > 0 and ((ta.change(d_ptp1_hit) and d_ptp1_hit) or (ta.change(d_ptp2_hit) and d_ptp2_hit))
if gap_ptp_hit
    alert("🎯 GAP P~TP REACHED\nStatus: Points Locked at " + str.tostring(t_locked_pts, "#.##"), alert.freq_once_per_bar)
if div_ptp_hit
    alert("🎯 DIV P~TP REACHED\nStatus: Points Locked at " + str.tostring(t_locked_pts, "#.##"), alert.freq_once_per_bar)